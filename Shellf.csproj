<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>Shellf</RootNamespace>
    <AssemblyName>Shellf</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Exe icon (Explorer, pinned taskbar). Replace Resources\Shellf.ico to rebrand. -->
    <ApplicationIcon>Resources\Shellf.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- Embedded for Window.Icon (title bar + running taskbar button) -->
    <Resource Include="Resources\Shellf.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.0" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2903.40" />
  </ItemGroup>

  <ItemGroup>
    <!-- terminal.html + xterm.js bundle, served to WebView2 via a virtual host mapping -->
    <None Remove="Assets\**" />
    <Content Include="Assets\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
