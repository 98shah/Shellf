<Window x:Class="Shellf.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="360"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Sidebar}"
        Foreground="{StaticResource Brush.Text}"
        FontFamily="Inter 18pt 18pt, Inter 18pt, Inter, Segoe UI" FontSize="13">
    <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Padding="18">
        <StackPanel>
            <TextBlock Text="Settings" FontWeight="SemiBold" Margin="0,0,0,14"/>
            <TextBlock Text="DEFAULT SHELL"
                       Foreground="{StaticResource Brush.TextMuted}"
                       FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                <ListBox x:Name="ShellList"
                         MaxHeight="200"
                         Padding="2">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Checkbox visual driven by row selection: clicking anywhere
                                 on the row selects it, which ticks the box. -->
                            <StackPanel Orientation="Horizontal">
                                <Grid VerticalAlignment="Center">
                                    <Border x:Name="Box" Width="15" Height="15"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource Brush.BorderFocus}"
                                            BorderThickness="1.5"/>
                                    <Path x:Name="Check"
                                          Data="M20 6 9 17 4 12"
                                          Stroke="#0A0A0A" StrokeThickness="2.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Stretch="Uniform" Width="9" Height="9"
                                          Visibility="Collapsed"/>
                                </Grid>
                                <TextBlock Text="{Binding DisplayName}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                             Value="True">
                                    <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.Accent}"/>
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                                    <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            <TextBlock Text="New tabs created with the + button (and each new group's first tab) use this shell."
                       Foreground="{StaticResource Brush.TextMuted}"
                       FontSize="11" TextWrapping="Wrap"
                       Margin="0,8,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" IsCancel="True" MinWidth="80" Margin="0,0,8,0"/>
                <Button Content="OK" IsDefault="True" Style="{StaticResource AccentButton}" MinWidth="80" Click="OnOk"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
