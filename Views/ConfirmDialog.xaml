<Window x:Class="Shellf.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="390"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Sidebar}"
        Foreground="{StaticResource Brush.Text}"
        FontFamily="Inter 18pt 18pt, Inter 18pt, Inter, Segoe UI" FontSize="13">
    <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Padding="18">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <TextBlock x:Name="MessageText"
                       Foreground="{StaticResource Brush.TextMuted}"
                       TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancel" IsCancel="True" MinWidth="80" Margin="0,0,8,0"/>
                <Button Content="Don't Save" MinWidth="92" Margin="0,0,8,0" Click="OnDontSave"/>
                <Button Content="Save" IsDefault="True" Style="{StaticResource AccentButton}" MinWidth="80" Click="OnSave"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
