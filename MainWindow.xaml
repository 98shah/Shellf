<Window x:Class="Shellf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Shellf.Views"
        xmlns:vm="clr-namespace:Shellf.ViewModels"
        Title="Shellf"
        Icon="Resources/Shellf.ico"
        Width="1200" Height="720"
        MinWidth="800" MinHeight="480"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Window}"
        Foreground="{StaticResource Brush.Text}"
        FontFamily="Inter 18pt 18pt, Inter 18pt, Inter, Segoe UI" FontSize="13">

    <Window.Resources>
        <views:ColorHexToBrushConverter x:Key="ColorHexToBrush"/>
        <views:ColorHexToAccentBrushConverter x:Key="ColorHexToAccent"/>
        <views:ShellIconConverter x:Key="ShellIcon"/>

        <Style x:Key="TreeRowStyle" TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <!-- Group rows can carry a user-picked tint; tabs have no ColorHex,
                 so the binding falls back to transparent. -->
            <Setter Property="Background"
                    Value="{Binding ColorHex, Converter={StaticResource ColorHexToBrush}, FallbackValue=Transparent}"/>
            <Style.Triggers>
                <!-- Ctrl+Click multi-selection highlight -->
                <DataTrigger Binding="{Binding IsMarked}" Value="True">
                    <Setter Property="Background" Value="#26FFFFFF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Rows inside a group: highlight still spans the full pane width; only the
             content is indented (via Padding), so selection is flush on both edges. -->
        <Style x:Key="TreeChildRowStyle" TargetType="TreeViewItem" BasedOn="{StaticResource TreeRowStyle}">
            <Setter Property="Padding" Value="16,0,2,0"/>
        </Style>
    </Window.Resources>

    <!-- Custom caption bar: Windows keeps drag/snap/double-click via CaptionHeight;
         we draw the bar content (centered brand) and the caption buttons ourselves. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34"
                      CornerRadius="0"
                      GlassFrameThickness="0,0,0,1"
                      ResizeBorderThickness="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveWorkspaceCommand}"/>
    </Window.InputBindings>

    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="260" MinWidth="180" MaxWidth="560"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= Title bar ================= -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" Height="34"
                Background="{StaticResource Brush.Sidebar}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Button Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0"
                        ToolTip="Toggle sidebar"
                        Click="OnToggleSidebar"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Image Source="{StaticResource Icon.PanelLeft}" Width="14" Height="14"/>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="Resources/Shellf.ico" Width="16" Height="16"/>
                    <TextBlock Text="SHELLF" FontWeight="Bold" FontSize="12.5"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource CaptionButton}" Content="&#xE921;" ToolTip="Minimize"
                            Click="OnMinimizeWindow" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MaxRestoreButton" Style="{StaticResource CaptionButton}" Content="&#xE922;"
                            Click="OnMaxRestoreWindow" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource CaptionCloseButton}" Content="&#xE8BB;" ToolTip="Close"
                            Click="OnCloseWindow" WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= Sidebar ================= -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource Brush.Sidebar}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="10">

                <!-- Top action row: + (60%) | menu (20%) | settings (20%) -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Margin="0,0,4,0"
                            ToolTip="New terminal (default shell)"
                            Command="{Binding AddDefaultTabCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource Icon.Plus}" Width="13" Height="13" VerticalAlignment="Center"/>
                            <TextBlock Text="Add Tab" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1"
                            Margin="0,0,4,0"
                            ToolTip="More"
                            Click="OnAddMenuClick">
                        <Image Source="{StaticResource Icon.ChevronDown}" Width="14" Height="14"/>
                        <!-- Items are built in code-behind from the detected shell catalog -->
                        <Button.ContextMenu>
                            <ContextMenu/>
                        </Button.ContextMenu>
                    </Button>
                    <Button Grid.Column="2"
                            ToolTip="Settings"
                            Command="{Binding OpenSettingsCommand}">
                        <Image Source="{StaticResource Icon.Settings}" Width="15" Height="15"/>
                    </Button>
                </Grid>

                <!-- Bottom: save + status -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Button ToolTip="Ctrl+S"
                            Command="{Binding SaveWorkspaceCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource Icon.Save}" Width="13" Height="13" VerticalAlignment="Center"/>
                            <TextBlock Text="Save Workspace" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource Brush.TextMuted}"
                               FontSize="11" TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Workspace tree: loose tabs and collapsible groups -->
                <TreeView x:Name="WorkspaceTree"
                          ItemsSource="{Binding Items}"
                          Margin="0,0,0,10"
                          ScrollViewer.CanContentScroll="False"
                          AllowDrop="True"
                          SelectedItemChanged="OnTreeSelectionChanged"
                          PreviewMouseLeftButtonDown="OnTreePreviewMouseDown"
                          PreviewMouseMove="OnTreePreviewMouseMove"
                          PreviewMouseWheel="OnTreeMouseWheel"
                          DragOver="OnTreeDragOver"
                          Drop="OnTreeDrop">
                    <TreeView.InputBindings>
                        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}"/>
                    </TreeView.InputBindings>
                    <TreeView.ItemContainerStyle>
                        <StaticResource ResourceKey="TreeRowStyle"/>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>

                        <!-- The app-level implicit ScrollBar style doesn't reach the
                             TreeView template's internals; re-scope it here so the
                             tree gets the slim themed bar instead of the system one. -->
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}"/>

                        <HierarchicalDataTemplate DataType="{x:Type vm:TabGroupViewModel}" ItemsSource="{Binding Tabs}"
                                                  ItemContainerStyle="{StaticResource TreeChildRowStyle}">
                            <Border Background="Transparent" Padding="4,6"
                                    MouseLeftButtonDown="OnGroupHeaderClick"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                <Border.ContextMenu>
                                    <ContextMenu Opened="OnGroupMenuOpened">
                                        <!-- Shell picker; populated on open from the detected catalog -->
                                        <MenuItem Header="Add Tab"/>
                                        <Separator/>
                                        <MenuItem Header="Colour">
                                            <MenuItem Command="{Binding SetColorCommand}" CommandParameter="#26F85149">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle Width="10" Height="10" Fill="#F85149" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Cherry" Margin="8,0,0,0"/>
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Command="{Binding SetColorCommand}" CommandParameter="#26818CF8">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle Width="10" Height="10" Fill="#818CF8" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Sky" Margin="8,0,0,0"/>
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <MenuItem Command="{Binding SetColorCommand}" CommandParameter="#263FB950">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle Width="10" Height="10" Fill="#3FB950" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Forest" Margin="8,0,0,0"/>
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <!-- Keep in sync with TabGroupViewModel.DefaultColorHex -->
                                            <MenuItem Command="{Binding SetColorCommand}" CommandParameter="#269CA3AF">
                                                <MenuItem.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle Width="10" Height="10" Fill="#9CA3AF" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Default" Margin="8,0,0,0"/>
                                                    </StackPanel>
                                                </MenuItem.Header>
                                            </MenuItem>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Rename"
                                                  Command="{Binding PlacementTarget.Tag.RenameItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Delete"
                                                  Command="{Binding PlacementTarget.Tag.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid x:Name="GroupRow">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <!-- GitHub-label style: the icon takes the group's accent colour -->
                                        <Path Data="{StaticResource Geometry.Folder}"
                                              Stroke="{Binding ColorHex, Converter={StaticResource ColorHexToAccent}}"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Stretch="Uniform" Width="13" Height="13"
                                              VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Tabs.Count, StringFormat=({0})}"
                                                   Foreground="{StaticResource Brush.TextMuted}"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="AddToGroupButton" Grid.Column="1"
                                            Style="{StaticResource GhostButton}" Padding="3"
                                            Opacity="0"
                                            ToolTip="New tab here (default shell)"
                                            VerticalAlignment="Center"
                                            Command="{Binding Tag.AddTabToGroupCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                            CommandParameter="{Binding}">
                                        <Image Source="{StaticResource Icon.Plus}" Width="11" Height="11"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <HierarchicalDataTemplate.Triggers>
                                <Trigger SourceName="GroupRow" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="AddToGroupButton" Property="Opacity" Value="1"/>
                                </Trigger>
                            </HierarchicalDataTemplate.Triggers>
                        </HierarchicalDataTemplate>

                        <DataTemplate DataType="{x:Type vm:TerminalTabViewModel}">
                            <Border Background="Transparent" Padding="4,6"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Create Group"
                                                  Command="{Binding PlacementTarget.Tag.GroupTabsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Rename"
                                                  Command="{Binding PlacementTarget.Tag.RenameItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Delete"
                                                  Command="{Binding PlacementTarget.Tag.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid x:Name="TabRow">
                                    <Grid.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding CurrentDirectory}"
                                                           Foreground="{StaticResource Brush.TextMuted}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Grid.ToolTip>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0"
                                           Source="{Binding ShellPath, Converter={StaticResource ShellIcon}}"
                                           Width="13" Height="13"
                                           VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}"/>
                                        <TextBlock Text="{Binding CurrentDirectory}"
                                                   FontSize="10.5"
                                                   Foreground="{StaticResource Brush.TextMuted}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="CloseTabButton" Grid.Column="2"
                                            Style="{StaticResource TabCloseButton}"
                                            Opacity="0"
                                            ToolTip="Close tab"
                                            VerticalAlignment="Center"
                                            Command="{Binding Tag.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="TabRow" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseTabButton" Property="Opacity" Value="1"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>

                    </TreeView.Resources>
                </TreeView>
            </DockPanel>
        </Border>

        <!-- Sidebar/terminal divider: thin visible line, 5px grab zone -->
        <GridSplitter x:Name="PaneSplitter" Grid.Row="1" Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="{StaticResource Brush.Window}"
                      Focusable="False"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ================= Main pane: toolbar strip + terminal ================= -->
        <Grid Grid.Row="1" Grid.Column="2" Background="{StaticResource Brush.TerminalBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Terminal toolbar: a floating card above the shell (panel bg + border,
                 like the sidebar buttons). Active tab identity on the left, action
                 icons on the right — extend with GhostButton+Image blocks. -->
            <Border Grid.Row="0" Height="38"
                    Margin="10,8,10,6"
                    Background="{StaticResource Brush.Panel}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1">
                <Grid Margin="10,0,6,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{Binding SelectedTab.ShellPath, Converter={StaticResource ShellIcon}}"
                               Width="13" Height="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedTab.Title}" FontWeight="SemiBold"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedTab.CurrentDirectory}"
                                   Foreground="{StaticResource Brush.TextMuted}" FontSize="11.5"
                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}"
                                ToolTip="Copy current path"
                                Command="{Binding CopyActivePathCommand}">
                            <Image Source="{StaticResource Icon.Copy}" Width="13" Height="13"/>
                        </Button>
                        <Button Style="{StaticResource GhostButton}" Margin="4,0,0,0"
                                ToolTip="Open current path in Explorer"
                                Command="{Binding OpenActivePathCommand}">
                            <Image Source="{StaticResource Icon.FolderOpen}" Width="13" Height="13"/>
                        </Button>
                        <Button x:Name="NotesButton" Style="{StaticResource GhostButton}" Margin="4,0,0,0"
                                ToolTip="Notes"
                                Click="OnToggleNotes">
                            <Image Source="{StaticResource Icon.Note}" Width="13" Height="13"/>
                        </Button>

                        <!-- Notes dropdown: floats OVER the terminal (popups have their own
                             surface, no airspace issue), closes on outside click. -->
                        <Popup x:Name="NotesPopup"
                               PlacementTarget="{Binding ElementName=NotesButton}"
                               Placement="Bottom"
                               HorizontalOffset="-336"
                               VerticalOffset="6"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Slide"
                               Closed="OnNotesPopupClosed">
                            <Border Width="360"
                                    Background="{StaticResource Brush.Panel}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    Padding="12">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <TextBlock Text="NOTES"
                                                   Foreground="{StaticResource Brush.TextMuted}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Button Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                                                ToolTip="Save notes"
                                                Command="{Binding SaveNotesCommand}">
                                            <Image Source="{StaticResource Icon.Save}" Width="13" Height="13"/>
                                        </Button>
                                    </Grid>
                                    <Button DockPanel.Dock="Bottom" Margin="0,10,0,0"
                                            Content="Copy to Input &amp; Run"
                                            ToolTip="Run the selection (or everything) in the active terminal"
                                            Click="OnCopyNoteToInput"/>
                                    <TextBox x:Name="NotesBox"
                                             Height="320"
                                             Text="{Binding NotesText, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" AcceptsTab="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             VerticalContentAlignment="Top"/>
                                </DockPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
            <TextBlock Text="No terminal selected — press + to open one."
                       Foreground="{StaticResource Brush.TextMuted}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <views:TerminalHostView
                ActiveSessionId="{Binding SelectedTab.SessionId, FallbackValue='', TargetNullValue=''}">
                <views:TerminalHostView.Style>
                    <Style TargetType="{x:Type views:TerminalHostView}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </views:TerminalHostView.Style>
            </views:TerminalHostView>
            </Grid>
        </Grid>

    </Grid>
</Window>
