<Window x:Class="Shellf.Views.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="360"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Sidebar}"
        Foreground="{StaticResource Brush.Text}"
        FontFamily="Inter 18pt 18pt, Inter 18pt, Inter, Segoe UI" FontSize="13">
    <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Padding="18">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <TextBox x:Name="Input"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" IsCancel="True" MinWidth="80" Margin="0,0,8,0"/>
                <Button Content="OK" IsDefault="True" Style="{StaticResource AccentButton}" MinWidth="80" Click="OnOk"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
